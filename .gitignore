# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# playwright-mcp scratch
/.playwright-mcp/
/.playwright-cli/

# Override global ~/.gitignore_global "/lib" — lib/ is app source here
!/lib
!/lib/**

# Design resources
design-resources/
design-artifacts/

# AI agent tooling (regenerable mirrors — not application source)
.agents/
.claude/

# impeccable (design system)
.impeccable/

# bmad
_bmad/
_bmad-output/
design-artifacts/
design-resources/

# bmad output
_bmad-output/